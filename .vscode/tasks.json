{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "npm update",
			"command": "npm",
			"args": [
				"update"
			],
			"options": {
				"cwd": "${workspaceFolder}/AppArch/frontend/BMFT"
			},
			"presentation": {
				"reveal": "silent"
			}
		},
		{
			"type": "docker-build",
			"label": "docker-build",
			"platform": "node",
			"dockerBuild": {
				"dockerfile": "${workspaceFolder}/Dockerfile",
				"context": "${workspaceFolder}",
				"pull": true
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: release",
			"dependsOn": [
				"docker-build"
			],
			"platform": "node"
		},
		{
			"type": "docker-run",
			"label": "docker-run: debug",
			"dependsOn": [
				"docker-build"
			],
			"dockerRun": {
				"env": {
					"DEBUG": "*",
					"NODE_ENV": "development"
				}
			},
			"node": {
				"enableDebugging": true
			}
		}
	]
}